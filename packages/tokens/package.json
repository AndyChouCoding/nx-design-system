{
  "name": "@andychoucoding/tokens",
  "version": "0.1.0",
  "description": "Design tokens for AndyChouCoding design system",
  "keywords": ["design-system", "design-tokens", "tokens"],
  "author": "AndyChouCoding",
  "license": "MIT",
  "sideEffects": false,
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "prepare": "tsup",
    "dev": "tsup --watch"
  },
  "devDependencies": {
    "tsup": "^8.5.1",
    "typescript": "~5.9.2"
  }
}
