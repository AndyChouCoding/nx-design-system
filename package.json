{
  "name": "@andychoucoding/design-system",
  "version": "0.0.0",
  "license": "MIT",
  "scripts": {
    "build": "pnpm --filter './packages/*' build",
    "storybook": "pnpm nx run storybook:storybook",
    "build-storybook": "pnpm nx run storybook:build-storybook",
    "changeset": "changeset",
    "version": "changeset version",
    "release": "pnpm build && changeset publish"
  },
  "private": true,
  "devDependencies": {
    "@changesets/cli": "^2.30.0",
    "@nx/js": "22.6.5",
    "@nx/react": "22.6.5",
    "@nx/storybook": "22.6.5",
    "@swc-node/register": "1.11.1",
    "@swc/core": "1.15.8",
    "@swc/helpers": "0.5.18",
    "nx": "22.6.5",
    "prettier": "^3.8.1",
    "tslib": "^2.3.0",
    "tsup": "^8.5.1",
    "typescript": "~5.9.2"
  },
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "pnpm": {
    "onlyBuiltDependencies": [
      "@swc/core",
      "esbuild",
      "nx"
    ]
  }
}
